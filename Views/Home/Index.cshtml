@model List<TodoApp.Models.Todo>
@{
    ViewData["Title"] = "My Todo List";
    var totalCount = Model.Count;
    var remainingCount = Model.Count(t => !t.IsCompleted);
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header -->
            <div class="text-center mb-4">
                <h1 class="display-4 fw-bold text-primary">
                    <i class="bi bi-check2-square"></i> My Todo List
                </h1>
                <p class="text-muted">Stay organized and get things done</p>
            </div>

            <!-- Add Todo Form -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">
                        <i class="bi bi-plus-circle"></i> Add New Task
                    </h5>
                    <form method="post" asp-action="Add" asp-controller="Home">
                        <div class="mb-3">
                            <input type="text" 
                                   class="form-control form-control-lg" 
                                   name="title" 
                                   placeholder="What needs to be done?" 
                                   required 
                                   autofocus />
                        </div>
                        <div class="mb-3">
                            <textarea class="form-control" 
                                      name="description" 
                                      rows="2" 
                                      placeholder="Add a note..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-plus-lg"></i> Add Task
                        </button>
                    </form>
                </div>
            </div>

            <!-- Todo List Summary -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Your Tasks</h5>
                <span class="badge bg-secondary fs-6">
                    @remainingCount remaining / @totalCount total
                </span>
            </div>

            <!-- Todo Items -->
            @if (Model.Any())
            {
                <div class="list-group shadow-sm">
                    @foreach (var todo in Model)
                    {
                        <div class="list-group-item @(todo.IsCompleted ? "bg-light" : "")">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <div class="flex-grow-1 me-3">
                                    <h5 class="mb-1 @(todo.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                        @if (todo.IsCompleted)
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-circle text-secondary"></i>
                                        }
                                        @todo.Title
                                    </h5>
                                    @if (!string.IsNullOrWhiteSpace(todo.Description))
                                    {
                                        <p class="mb-1 text-muted small @(todo.IsCompleted ? "text-decoration-line-through" : "")">
                                            @todo.Description
                                        </p>
                                    }
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3"></i> @todo.CreatedAt.ToString("MMM dd, yyyy")
                                    </small>
                                </div>
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <form method="post" asp-action="Toggle" asp-controller="Home" class="d-inline">
                                        <input type="hidden" name="id" value="@todo.Id" />
                                        @if (todo.IsCompleted)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-arrow-counterclockwise"></i> Undo
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="bi bi-check-lg"></i> Done
                                            </button>
                                        }
                                    </form>
                                    <form method="post" asp-action="Delete" asp-controller="Home" class="d-inline">
                                        <input type="hidden" name="id" value="@todo.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-inbox display-1 text-muted"></i>
                        <h5 class="mt-3 text-muted">No tasks yet</h5>
                        <p class="text-muted">Add your first task to get started!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
